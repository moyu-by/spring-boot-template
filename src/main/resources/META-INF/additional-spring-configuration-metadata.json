{
  "properties": [
    {
      "name": "key-path",
      "type": "java.lang.String",
      "description": "RSA 密钥文件路径。默认 classpath:key，从 resources/key/ 下加载 private.pem 和 public.pem",
      "defaultValue": "classpath:key"
    },
    {
      "name": "jwt.secret-key",
      "type": "java.lang.String",
      "description": "JWT HMAC-SHA256 签名密钥。生产环境务必更换，可使用 openssl rand -hex 32 生成",
      "sourceType": "com.example.demo.config.JwtProperties"
    },
    {
      "name": "jwt.ttl",
      "type": "java.lang.Long",
      "description": "JWT token 过期时间（毫秒）",
      "defaultValue": "604800000"
    },
    {
      "name": "file.protocol",
      "type": "java.lang.String",
      "description": "文件访问协议",
      "defaultValue": "http"
    },
    {
      "name": "file.host",
      "type": "java.lang.String",
      "description": "文件服务器地址",
      "defaultValue": "localhost"
    },
    {
      "name": "file.port",
      "type": "java.lang.Integer",
      "description": "文件服务器端口",
      "defaultValue": "8080"
    },
    {
      "name": "file.sub-path",
      "type": "java.lang.String",
      "description": "文件 URL 子路径，如 /file/",
      "defaultValue": "file"
    },
    {
      "name": "file.store-path",
      "type": "java.lang.String",
      "description": "文件本地存储目录",
      "defaultValue": "./upload"
    }
  ]
}
